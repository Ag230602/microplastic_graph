[
  {
    "title": "Association",
    "description": "An interpreted relationship between biological, mechanistic, biomarker, or clinical entities, separated from raw observations and qualified by evidentiary strength.",
    "type": "object",
    "required": ["id", "type", "relationship", "evidence_strength"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "description": "Unique association identifier." },
      "type": { "const": "Association", "description": "Type tag for the node." },
      "relationship": {
        "type": "string",
        "enum": [
          "associated_with",
          "correlates_with",
          "suggests",
          "causal_evidence",
          "protective",
          "null"
        ]
      },
      "direction": {
        "type": "string",
        "enum": ["increase", "decrease", "variable", "none", "unknown"]
      },
      "effect_size": { "type": "number" },
      "effect_metric": { "type": "string" },
      "p_value": { "type": "number" },
      "confidence": { "type": "number" },
      "evidence_strength": {
        "type": "string",
        "enum": ["limited", "moderate", "strong"]
      },
      "consistency_across_studies": {
        "type": "string",
        "enum": ["low", "medium", "high", "unknown"]
      },
      "study_scope": { "type": "string" },
      "causal_confidence": {
        "type": "string",
        "enum": ["low", "medium", "high", "unknown"]
      },
      "notes": { "type": "string" }
    }
  },
